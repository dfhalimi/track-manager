<div class="flex items-start justify-between gap-4 border-b border-slate-200 px-6 py-4">
    <div>
        <h2 class="text-lg font-semibold text-slate-900">{{ view.title }}</h2>
        <p class="mt-1 text-sm text-slate-600">{{ view.description }}</p>
    </div>
    <form method="dialog">
        <button type="submit" class="rounded border border-slate-300 px-3 py-2 text-sm text-slate-700">Schließen</button>
    </form>
</div>

<div class="max-h-[70vh] overflow-y-auto px-6 py-4">
    {% if view.entries is empty %}
        <p class="text-sm text-slate-500">Es sind noch keine Historieneinträge vorhanden.</p>
    {% else %}
        <div class="space-y-4">
            {% for entry in view.entries %}
                <article class="rounded border border-slate-200 bg-white p-4">
                    <div class="flex items-start justify-between gap-4">
                        <div>
                            <h3 class="font-medium text-slate-900">{{ entry.summary }}</h3>
                            {% if entry.isSynthetic %}
                                <p class="mt-1 text-xs text-slate-500">Aus bestehendem Datensatz übernommen</p>
                            {% endif %}
                        </div>
                        <span class="shrink-0 text-xs text-slate-500">{{ entry.occurredAtLabel }}</span>
                    </div>

                    {% if entry.details is not empty %}
                        <ul class="mt-3 space-y-1 text-sm text-slate-700">
                            {% for detail in entry.details %}
                                <li>{{ detail }}</li>
                            {% endfor %}
                        </ul>
                    {% endif %}
                </article>
            {% endfor %}
        </div>
    {% endif %}
</div>
