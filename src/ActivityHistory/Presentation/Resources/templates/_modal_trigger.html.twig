<div class="flex shrink-0 items-center" data-controller="activity-history-modal" data-activity-history-modal-url-value="{{ historyUrl }}">
    {% if variant|default('icon') == 'button' %}
        <button
            type="button"
            title="{{ buttonTitle }}"
            aria-label="{{ buttonTitle }}"
            class="rounded border border-slate-300 px-4 py-2 text-sm font-medium text-slate-900"
            data-action="activity-history-modal#open"
        >{{ buttonLabel|default('Historie') }}</button>
    {% else %}
        <button type="button" title="{{ buttonTitle }}" aria-label="{{ buttonTitle }}" class="inline-flex h-8 w-8 appearance-none items-center justify-center border-0 bg-transparent p-0 text-slate-600 transition hover:text-slate-900" data-action="activity-history-modal#open">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="h-4 w-4">
                <path fill-rule="evenodd" d="M3.25 4A1.75 1.75 0 0 1 5 2.25h7.19c.464 0 .909.184 1.237.513l3.81 3.81c.329.328.513.773.513 1.237V16A1.75 1.75 0 0 1 16 17.75H5A1.75 1.75 0 0 1 3.25 16V4Zm2.5 1.25a.75.75 0 0 0-.75.75v8a.75.75 0 0 0 1.5 0V6a.75.75 0 0 0-.75-.75Zm3.25 0a.75.75 0 0 0 0 1.5h4a.75.75 0 0 0 0-1.5h-4Zm0 3a.75.75 0 0 0 0 1.5h4a.75.75 0 0 0 0-1.5h-4Zm0 3a.75.75 0 0 0 0 1.5h2.5a.75.75 0 0 0 0-1.5H9Z" clip-rule="evenodd" />
            </svg>
        </button>
    {% endif %}
    <dialog
        class="fixed left-1/2 top-1/2 m-0 w-full max-w-4xl -translate-x-1/2 -translate-y-1/2 rounded border border-slate-200 p-0 shadow-xl backdrop:bg-slate-900/30"
        data-activity-history-modal-target="dialog"
        data-action="click->activity-history-modal#closeOnBackdrop"
    >
        <div data-activity-history-modal-target="content">
            <div class="p-6 text-sm text-slate-500">Lade Historie ...</div>
        </div>
    </dialog>
</div>
