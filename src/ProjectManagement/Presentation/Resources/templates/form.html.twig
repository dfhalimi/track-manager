{% extends '@common.presentation/base_appshell.html.twig' %}

{% block body %}
    <div class="mx-auto max-w-3xl space-y-6 p-6">
        <div>
            <nav class="mb-2 flex flex-wrap items-center gap-4 text-sm text-slate-600">
                <a href="{{ path('track_management.presentation.index') }}" class="underline">Zur Trackliste</a>
                <a href="{{ path('project_management.presentation.index') }}" class="underline">Zu Projekten</a>
            </nav>
            <h1 class="text-3xl font-semibold text-slate-900">{{ view.isEditMode ? 'Projekt bearbeiten' : 'Projekt erstellen' }}</h1>
            <p class="text-sm text-slate-600">Lege Titel, Kategorie und Cover für das Projekt fest.</p>
        </div>

        {% for type, messages in app.flashes %}
            {% for message in messages %}
                <div class="rounded border px-4 py-3 text-sm {{ type == 'error' ? 'border-red-200 bg-red-50 text-red-700' : 'border-emerald-200 bg-emerald-50 text-emerald-700' }}">
                    {{ message }}
                </div>
            {% endfor %}
        {% endfor %}

        <form
            method="post"
            action="{{ view.formAction }}"
            enctype="multipart/form-data"
            class="space-y-4 rounded border border-slate-200 bg-white p-6"
            data-controller="project-form project-image-upload"
            data-project-image-upload-auto-submit-value="false"
            data-project-image-upload-target-size-value="3000"
        >
            <div class="grid gap-4 md:grid-cols-2">
                <div>
                    <label class="mb-1 block text-sm font-medium text-slate-700">Projekt-Titel</label>
                    <input type="text" name="title" value="{{ view.title }}" class="w-full rounded border border-slate-300 px-3 py-2 text-sm">
                </div>
                <div>
                    <label class="mb-1 block text-sm font-medium text-slate-700">Kategorie</label>
                    <input type="text" name="category_name" value="{{ view.categoryName }}" list="project-category-options" autocomplete="off" class="w-full rounded border border-slate-300 px-3 py-2 text-sm">
                    <datalist id="project-category-options">
                        {% for categoryOption in view.categoryOptions %}
                            <option value="{{ categoryOption }}"></option>
                        {% endfor %}
                    </datalist>
                    <p class="mt-1 text-xs text-slate-500">Bestehende Kategorien können wiederverwendet oder direkt neu angelegt werden.</p>
                </div>
            </div>

            <div>
                <label class="mb-1 block text-sm font-medium text-slate-700">Interpreten</label>
                <div class="space-y-2" data-project-form-target="artistList">
                    {% for artist in view.artists %}
                        <input type="text" name="artists[]" value="{{ artist }}" class="w-full rounded border border-slate-300 px-3 py-2 text-sm">
                    {% endfor %}
                </div>
                <template data-project-form-target="artistTemplate">
                    <input type="text" name="artists[]" value="" class="w-full rounded border border-slate-300 px-3 py-2 text-sm">
                </template>
                <div class="mt-2 flex flex-wrap gap-2">
                    <button type="button" class="rounded border border-slate-300 px-3 py-2 text-sm font-medium text-slate-900" data-action="project-form#addArtist">+ Interpreten hinzufügen</button>
                    <button type="button" class="rounded border border-slate-300 px-3 py-2 text-sm font-medium text-slate-900" data-project-form-target="removeArtistButton" data-action="project-form#removeLastArtist">Letzten Interpreten entfernen</button>
                </div>
                <p class="mt-1 text-xs text-slate-500">Optional. Du kannst keinen, einen oder mehrere Interpreten hinterlegen.</p>
            </div>

            {% if view.isEditMode and view.published %}
                <div>
                    <label class="mb-1 block text-sm font-medium text-slate-700">Veröffentlicht am</label>
                    <input
                        type="datetime-local"
                        name="published_at"
                        value="{{ view.publishedAtInputValue }}"
                        max="{{ view.publishedAtMaxValue }}"
                        required
                        class="w-full rounded border border-slate-300 px-3 py-2 text-sm md:w-auto md:min-w-[18rem]"
                    >
                    <p class="mt-1 text-xs text-slate-500">Nur für bereits veröffentlichte Projekte. Das Datum kann rückwirkend angepasst werden, aber nicht in der Zukunft liegen.</p>
                </div>
            {% endif %}

            <div>
                <label class="mb-1 block text-sm font-medium text-slate-700">{{ view.isEditMode ? 'Projektbild ersetzen (optional)' : 'Projektbild (optional)' }}</label>
                <input
                    type="file"
                    name="project_image"
                    accept=".jpg,.jpeg,.png,image/jpeg,image/png"
                    class="w-full rounded border border-slate-300 px-3 py-2 text-sm"
                    data-project-image-upload-target="input"
                    data-action="change->project-image-upload#selectFile"
                >
                <p class="mt-1 text-xs text-slate-500">Erlaubte Formate: JPG oder PNG. Empfohlen: quadratisch, idealerweise 3000 x 3000 px, mindestens 1400 x 1400 px.</p>
                <p class="mt-1 text-xs text-slate-500">Nach der Auswahl öffnet sich direkt ein verpflichtender quadratischer Zuschnitt für das Spotify-Cover.</p>
            </div>

            <div class="flex items-center gap-3">
                <button type="submit" class="rounded bg-slate-900 px-4 py-2 text-sm font-medium text-white">{{ view.submitLabel }}</button>
                <a href="{{ view.cancelUrl }}" class="text-sm text-slate-600 underline">Abbrechen</a>
            </div>

            {% include '@projectmanagement.presentation/_project_image_crop_dialog.html.twig' %}
        </form>
    </div>
{% endblock %}
