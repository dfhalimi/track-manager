<div class="space-y-4" data-live-search-current-page="{{ view.currentPage }}">
    <div class="space-y-3 md:hidden">
        {% for item in view.items %}
            <article class="rounded border border-slate-200 bg-white p-4 shadow-sm {{ item.cancelled ? 'opacity-60' : '' }}">
                <div class="mb-3 flex items-start justify-between gap-3">
                    <div class="min-w-0">
                        <p class="text-sm font-medium text-slate-900">{{ item.title }}</p>
                        <p class="text-xs uppercase tracking-wide text-slate-500">{{ item.categoryName }}</p>
                        <div class="mt-2 space-y-1 text-xs text-slate-600">
                            {% if item.artists is empty %}
                                <p>-</p>
                            {% else %}
                                {% for artist in item.artists %}
                                    <p>{{ artist }}</p>
                                {% endfor %}
                            {% endif %}
                        </div>
                    </div>
                    <div class="flex flex-col items-end gap-2">
                        <span class="shrink-0 rounded bg-slate-100 px-2 py-1 text-xs font-medium text-slate-700">{{ item.trackCount }} Tracks</span>
                        <label class="flex items-center gap-2 text-xs text-slate-600">
                            <span>Published</span>
                            <span
                                class="inline-flex h-4 w-4 items-center justify-center rounded border {{ item.published ? 'border-emerald-200 bg-emerald-100 text-emerald-700' : 'border-slate-300 bg-white text-transparent' }}"
                                aria-label="{{ item.published ? 'Veröffentlicht' : 'Nicht veröffentlicht' }}"
                                title="{{ item.published ? 'Veröffentlicht' : 'Nicht veröffentlicht' }}"
                            >
                                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" fill="currentColor" class="h-3 w-3">
                                    <path fill-rule="evenodd" d="M13.28 4.22a.75.75 0 0 1 0 1.06l-6.25 6.25a.75.75 0 0 1-1.06 0L2.72 8.28a.75.75 0 1 1 1.06-1.06l2.72 2.72 5.72-5.72a.75.75 0 0 1 1.06 0Z" clip-rule="evenodd" />
                                </svg>
                            </span>
                        </label>
                    </div>
                </div>

                <div class="mt-4 flex justify-end gap-2">
                    {% include '@activityhistory.presentation/_modal_trigger.html.twig' with { historyUrl: item.historyUrl, buttonTitle: 'Historie anzeigen' } only %}
                    <a href="{{ item.showUrl }}" title="Details" aria-label="Details" class="inline-flex h-8 w-8 items-center justify-center text-slate-600 transition hover:text-slate-900">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="h-4 w-4">
                            <path d="M10 4.5c-3.878 0-7.162 2.285-8.327 5.5C2.838 13.215 6.122 15.5 10 15.5s7.162-2.285 8.327-5.5C17.162 6.785 13.878 4.5 10 4.5ZM10 13a3 3 0 1 1 0-6 3 3 0 0 1 0 6Z" />
                        </svg>
                    </a>
                    {% if not item.cancelled %}
                        <a href="{{ item.editUrl }}" title="Bearbeiten" aria-label="Bearbeiten" class="inline-flex h-8 w-8 items-center justify-center text-slate-600 transition hover:text-slate-900">
                            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="h-4 w-4">
                                <path d="m13.5 4.5 2 2L7.75 14.25l-2.5.5.5-2.5L13.5 4.5Zm1.06-1.06a1.5 1.5 0 0 1 2.122 0l.879.878a1.5 1.5 0 0 1 0 2.122l-.652.652-2-2 .651-.646Z" />
                            </svg>
                        </a>
                    {% endif %}
                </div>
            </article>
        {% else %}
            <div class="rounded border border-slate-200 bg-white px-4 py-8 text-center text-slate-500">Noch keine Projekte vorhanden.</div>
        {% endfor %}
    </div>

    <div class="hidden overflow-x-auto rounded border border-slate-200 bg-white md:block">
        <table class="min-w-[48rem] w-full table-fixed divide-y divide-slate-200 text-sm lg:min-w-0">
            <colgroup>
                <col class="w-[30%]">
                <col class="w-[16%]">
                <col class="w-[24%]">
                <col class="w-[10%]">
                <col class="w-[12%]">
                <col class="w-[8%]">
            </colgroup>
            <thead class="bg-slate-50">
                <tr>
                    <th class="px-3 py-3 text-left font-medium text-slate-600">Titel</th>
                    <th class="px-3 py-3 text-left font-medium text-slate-600">Kategorie</th>
                    <th class="px-3 py-3 text-left font-medium text-slate-600">Interpreten</th>
                    <th class="px-3 py-3 text-left font-medium text-slate-600">Published</th>
                    <th class="px-3 py-3 text-left font-medium text-slate-600">Tracks</th>
                    <th class="px-3 py-3 text-left font-medium text-slate-600">Aktionen</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-slate-100">
                {% for item in view.items %}
                    <tr class="{{ item.cancelled ? 'bg-slate-50 opacity-60' : '' }}">
                        <td class="px-3 py-3 font-medium text-slate-900">{{ item.title }}</td>
                        <td class="px-3 py-3 text-slate-700">{{ item.categoryName }}</td>
                        <td class="px-3 py-3 text-slate-700">
                            <div class="space-y-1">
                                {% if item.artists is empty %}
                                    <p>-</p>
                                {% else %}
                                    {% for artist in item.artists %}
                                        <p>{{ artist }}</p>
                                    {% endfor %}
                                {% endif %}
                            </div>
                        </td>
                        <td class="px-3 py-3 text-slate-700">
                            <span
                                class="inline-flex h-4 w-4 items-center justify-center rounded border {{ item.published ? 'border-emerald-200 bg-emerald-100 text-emerald-700' : 'border-slate-300 bg-white text-transparent' }}"
                                aria-label="{{ item.published ? 'Veröffentlicht' : 'Nicht veröffentlicht' }}"
                                title="{{ item.published ? 'Veröffentlicht' : 'Nicht veröffentlicht' }}"
                            >
                                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" fill="currentColor" class="h-3 w-3">
                                    <path fill-rule="evenodd" d="M13.28 4.22a.75.75 0 0 1 0 1.06l-6.25 6.25a.75.75 0 0 1-1.06 0L2.72 8.28a.75.75 0 1 1 1.06-1.06l2.72 2.72 5.72-5.72a.75.75 0 0 1 1.06 0Z" clip-rule="evenodd" />
                                </svg>
                            </span>
                        </td>
                        <td class="px-3 py-3 text-slate-700">{{ item.trackCount }}</td>
                        <td class="px-3 py-3">
                            <div class="flex justify-end gap-2">
                                {% include '@activityhistory.presentation/_modal_trigger.html.twig' with { historyUrl: item.historyUrl, buttonTitle: 'Historie anzeigen' } only %}
                                <a href="{{ item.showUrl }}" title="Details" aria-label="Details" class="inline-flex h-8 w-8 items-center justify-center text-slate-600 transition hover:text-slate-900">
                                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="h-4 w-4">
                                        <path d="M10 4.5c-3.878 0-7.162 2.285-8.327 5.5C2.838 13.215 6.122 15.5 10 15.5s7.162-2.285 8.327-5.5C17.162 6.785 13.878 4.5 10 4.5ZM10 13a3 3 0 1 1 0-6 3 3 0 0 1 0 6Z" />
                                    </svg>
                                </a>
                                {% if not item.cancelled %}
                                    <a href="{{ item.editUrl }}" title="Bearbeiten" aria-label="Bearbeiten" class="inline-flex h-8 w-8 items-center justify-center text-slate-600 transition hover:text-slate-900">
                                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="h-4 w-4">
                                            <path d="m13.5 4.5 2 2L7.75 14.25l-2.5.5.5-2.5L13.5 4.5Zm1.06-1.06a1.5 1.5 0 0 1 2.122 0l.879.878a1.5 1.5 0 0 1 0 2.122l-.652.652-2-2 .651-.646Z" />
                                        </svg>
                                    </a>
                                {% endif %}
                            </div>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="6" class="px-4 py-8 text-center text-slate-500">Noch keine Projekte vorhanden.</td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>

    <div class="flex flex-col gap-3 rounded border border-slate-200 bg-white p-4 sm:flex-row sm:items-center sm:justify-between">
        <p class="text-sm text-slate-600">
            {{ view.totalItems }} {{ view.totalItems == 1 ? 'Treffer' : 'Treffer' }} · Seite {{ view.currentPage }} von {{ view.totalPages }}
        </p>
        <div class="flex flex-wrap items-center gap-2">
            {% if view.previousPageUrl %}
                <a href="{{ view.previousPageUrl }}" data-live-search-page="{{ view.currentPage - 1 }}" class="rounded border border-slate-300 px-3 py-2 text-sm text-slate-900">Zurück</a>
            {% endif %}
            {% for pageLink in view.pageLinks %}
                <a
                    href="{{ pageLink.url }}"
                    data-live-search-page="{{ pageLink.page }}"
                    class="rounded border px-3 py-2 text-sm {{ pageLink.isCurrent ? 'border-slate-900 bg-slate-900 text-white' : 'border-slate-300 text-slate-900' }}"
                >{{ pageLink.page }}</a>
            {% endfor %}
            {% if view.nextPageUrl %}
                <a href="{{ view.nextPageUrl }}" data-live-search-page="{{ view.currentPage + 1 }}" class="rounded border border-slate-300 px-3 py-2 text-sm text-slate-900">Weiter</a>
            {% endif %}
        </div>
    </div>
</div>
