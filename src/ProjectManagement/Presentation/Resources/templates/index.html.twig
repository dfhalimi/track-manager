{% extends '@common.presentation/base_appshell.html.twig' %}

{% block body %}
    <div
        class="mx-auto w-full max-w-6xl space-y-6 p-4 sm:p-6"
        data-controller="live-search"
        data-action="click->live-search#handleClick"
        data-live-search-index-url-value="{{ view.indexUrl }}"
        data-live-search-list-url-value="{{ view.listUrl }}"
        data-live-search-suggestions-url-value="{{ view.suggestionsUrl }}"
        data-live-search-debounce-ms-value="200"
    >
        <div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
            <div class="space-y-2">
                <a href="{{ view.tracksIndexUrl }}" class="text-sm text-slate-600 underline">Zur Trackliste</a>
                <div>
                    <h1 class="text-3xl font-semibold text-slate-900">Projekte</h1>
                    <p class="text-sm text-slate-600">Verwalte Releases, Kategorien und Track-Reihenfolgen.</p>
                </div>
            </div>
            <a href="{{ view.createUrl }}" class="inline-flex items-center justify-center rounded bg-slate-900 px-4 py-2 text-sm font-medium text-white">Neues Projekt erstellen</a>
        </div>

        {% for type, messages in app.flashes %}
            {% for message in messages %}
                <div class="rounded border px-4 py-3 text-sm {{ type == 'error' ? 'border-red-200 bg-red-50 text-red-700' : 'border-emerald-200 bg-emerald-50 text-emerald-700' }}">
                    {{ message }}
                </div>
            {% endfor %}
        {% endfor %}

        <form
            method="get"
            action="{{ view.indexUrl }}"
            class="grid gap-3 rounded border border-slate-200 bg-white p-4 md:grid-cols-6 md:gap-4"
            data-live-search-target="form"
            data-action="submit->live-search#submitForm"
        >
            <input type="hidden" name="page" value="{{ view.currentPage }}" data-live-search-target="page">

            <div class="relative">
                <input
                    type="text"
                    name="q"
                    value="{{ view.searchQuery }}"
                    placeholder="Suche nach Projekt oder Kategorie"
                    class="w-full rounded border border-slate-300 px-3 py-2 text-sm"
                    autocomplete="off"
                    data-live-search-target="searchInput"
                    data-action="input->live-search#handleSearchInput keydown->live-search#handleKeydown focus->live-search#handleSearchFocus blur->live-search#handleSearchBlur"
                >
                <div
                    class="absolute left-0 right-0 z-10 mt-1 hidden max-h-80 overflow-y-auto rounded border border-slate-200 bg-white shadow-lg"
                    data-live-search-target="suggestions"
                ></div>
            </div>

            <select name="category" class="rounded border border-slate-300 px-3 py-2 text-sm" data-action="change->live-search#handleFilterChange">
                <option value="">Alle Kategorien</option>
                {% for categoryOption in view.categoryOptions %}
                    <option value="{{ categoryOption }}" {{ view.categoryFilter == categoryOption ? 'selected' : '' }}>{{ categoryOption }}</option>
                {% endfor %}
            </select>

            <select name="cancelled" class="rounded border border-slate-300 px-3 py-2 text-sm" data-action="change->live-search#handleFilterChange">
                <option value="">Alle Projekte</option>
                <option value="active" {{ view.cancelledFilter == 'active' ? 'selected' : '' }}>Aktiv</option>
                <option value="cancelled" {{ view.cancelledFilter == 'cancelled' ? 'selected' : '' }}>Archiviert</option>
            </select>

            <select name="sortBy" class="rounded border border-slate-300 px-3 py-2 text-sm" data-action="change->live-search#handleFilterChange">
                <option value="updatedAt" {{ view.sortBy == 'updatedAt' ? 'selected' : '' }}>Letzte Änderung</option>
                <option value="title" {{ view.sortBy == 'title' ? 'selected' : '' }}>Titel</option>
                <option value="trackCount" {{ view.sortBy == 'trackCount' ? 'selected' : '' }}>Track-Anzahl</option>
            </select>

            <select name="sortDirection" class="rounded border border-slate-300 px-3 py-2 text-sm" data-action="change->live-search#handleFilterChange">
                <option value="DESC" {{ view.sortDirection == 'DESC' ? 'selected' : '' }}>Absteigend</option>
                <option value="ASC" {{ view.sortDirection == 'ASC' ? 'selected' : '' }}>Aufsteigend</option>
            </select>

            <div class="flex gap-2">
                <select name="perPage" class="w-full rounded border border-slate-300 px-3 py-2 text-sm" data-action="change->live-search#handleFilterChange">
                    {% for perPageOption in view.perPageOptions %}
                        <option value="{{ perPageOption }}" {{ view.perPage == perPageOption ? 'selected' : '' }}>{{ perPageOption }} / Seite</option>
                    {% endfor %}
                </select>
                <button type="submit" class="rounded bg-slate-900 px-4 py-2 text-sm font-medium text-white">Filtern</button>
            </div>
        </form>

        <div data-live-search-target="list">
            {% include '@projectmanagement.presentation/_list.html.twig' with { view: view } only %}
        </div>
    </div>
{% endblock %}
