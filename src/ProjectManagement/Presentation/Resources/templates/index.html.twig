{% extends '@common.presentation/base_appshell.html.twig' %}

{% block body %}
    <div class="mx-auto w-full max-w-6xl space-y-6 p-4 sm:p-6">
        <div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
            <div class="space-y-2">
                <a href="{{ view.tracksIndexUrl }}" class="text-sm text-slate-600 underline">Zur Trackliste</a>
                <div>
                    <h1 class="text-3xl font-semibold text-slate-900">Projekte</h1>
                    <p class="text-sm text-slate-600">Verwalte Releases, Kategorien und Track-Reihenfolgen.</p>
                </div>
            </div>
            <a href="{{ view.createUrl }}" class="inline-flex items-center justify-center rounded bg-slate-900 px-4 py-2 text-sm font-medium text-white">Neues Projekt erstellen</a>
        </div>

        {% for type, messages in app.flashes %}
            {% for message in messages %}
                <div class="rounded border px-4 py-3 text-sm {{ type == 'error' ? 'border-red-200 bg-red-50 text-red-700' : 'border-emerald-200 bg-emerald-50 text-emerald-700' }}">
                    {{ message }}
                </div>
            {% endfor %}
        {% endfor %}

        <form method="get" class="grid gap-3 rounded border border-slate-200 bg-white p-4 md:grid-cols-4 md:gap-4">
            <input type="text" name="q" value="{{ view.searchQuery }}" placeholder="Suche nach Projekt oder Kategorie" class="rounded border border-slate-300 px-3 py-2 text-sm">
            <select name="category" class="rounded border border-slate-300 px-3 py-2 text-sm">
                <option value="">Alle Kategorien</option>
                {% for categoryOption in view.categoryOptions %}
                    <option value="{{ categoryOption }}" {{ view.categoryFilter == categoryOption ? 'selected' : '' }}>{{ categoryOption }}</option>
                {% endfor %}
            </select>
            <select name="sortBy" class="rounded border border-slate-300 px-3 py-2 text-sm">
                <option value="updatedAt" {{ view.sortBy == 'updatedAt' ? 'selected' : '' }}>Letzte Änderung</option>
                <option value="title" {{ view.sortBy == 'title' ? 'selected' : '' }}>Titel</option>
                <option value="trackCount" {{ view.sortBy == 'trackCount' ? 'selected' : '' }}>Track-Anzahl</option>
            </select>
            <div class="flex gap-2">
                <select name="sortDirection" class="w-full rounded border border-slate-300 px-3 py-2 text-sm">
                    <option value="DESC" {{ view.sortDirection == 'DESC' ? 'selected' : '' }}>Absteigend</option>
                    <option value="ASC" {{ view.sortDirection == 'ASC' ? 'selected' : '' }}>Aufsteigend</option>
                </select>
                <button type="submit" class="rounded bg-slate-900 px-4 py-2 text-sm font-medium text-white">Filtern</button>
            </div>
        </form>

        <div class="space-y-3 md:hidden">
            {% for item in view.items %}
                <article class="rounded border border-slate-200 bg-white p-4 shadow-sm">
                    <div class="mb-3 flex items-start justify-between gap-3">
                        <div class="min-w-0">
                            <p class="text-sm font-medium text-slate-900">{{ item.title }}</p>
                            <p class="text-xs uppercase tracking-wide text-slate-500">{{ item.categoryName }}</p>
                        </div>
                        <span class="shrink-0 rounded bg-slate-100 px-2 py-1 text-xs font-medium text-slate-700">{{ item.trackCount }} Tracks</span>
                    </div>

                    <div class="mt-4 flex gap-3">
                        <a href="{{ item.showUrl }}" class="text-sm font-medium text-slate-900 underline">Details</a>
                        <a href="{{ item.editUrl }}" class="text-sm font-medium text-slate-900 underline">Bearbeiten</a>
                    </div>
                </article>
            {% else %}
                <div class="rounded border border-slate-200 bg-white px-4 py-8 text-center text-slate-500">Noch keine Projekte vorhanden.</div>
            {% endfor %}
        </div>

        <div class="hidden overflow-x-auto rounded border border-slate-200 bg-white md:block">
            <table class="min-w-[42rem] w-full table-fixed divide-y divide-slate-200 text-sm lg:min-w-0">
                <colgroup>
                    <col class="w-[42%]">
                    <col class="w-[20%]">
                    <col class="w-[16%]">
                    <col class="w-[22%]">
                </colgroup>
                <thead class="bg-slate-50">
                    <tr>
                        <th class="px-3 py-3 text-left font-medium text-slate-600">Titel</th>
                        <th class="px-3 py-3 text-left font-medium text-slate-600">Kategorie</th>
                        <th class="px-3 py-3 text-left font-medium text-slate-600">Tracks</th>
                        <th class="px-3 py-3 text-left font-medium text-slate-600">Aktionen</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-100">
                    {% for item in view.items %}
                        <tr>
                            <td class="px-3 py-3 font-medium text-slate-900">{{ item.title }}</td>
                            <td class="px-3 py-3 text-slate-700">{{ item.categoryName }}</td>
                            <td class="px-3 py-3 text-slate-700">{{ item.trackCount }}</td>
                            <td class="px-3 py-3">
                                <div class="flex flex-col gap-1 xl:flex-row xl:gap-2">
                                    <a href="{{ item.showUrl }}" class="text-slate-900 underline">Details</a>
                                    <a href="{{ item.editUrl }}" class="text-slate-900 underline">Bearbeiten</a>
                                </div>
                            </td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="4" class="px-4 py-8 text-center text-slate-500">Noch keine Projekte vorhanden.</td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
{% endblock %}
