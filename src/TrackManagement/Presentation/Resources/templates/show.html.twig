{% extends '@common.presentation/base_appshell.html.twig' %}

{% block body %}
    <div class="mx-auto max-w-5xl space-y-6 p-6">
        <div>
            <a href="{{ view.backToListUrl }}" class="text-sm text-slate-600 underline">Zurück zur Trackliste</a>
        </div>

        <div class="flex items-start justify-between gap-4">
            <div>
                <p class="text-sm text-slate-500">TrackNumber {{ view.trackNumber }}</p>
                <h1 class="text-3xl font-semibold text-slate-900">{{ view.title }}</h1>
                <p class="text-sm text-slate-600">{{ view.beatName }} · {{ view.bpmLabel }} BPM · {{ view.musicalKeyLabel }}</p>
            </div>
            <div class="flex gap-3">
                <a href="{{ view.editUrl }}" class="rounded border border-slate-300 px-4 py-2 text-sm font-medium text-slate-900">Bearbeiten</a>
                <form method="post" action="{{ view.deleteUrl }}">
                    <input type="hidden" name="_token" value="{{ csrf_token('delete_track_' ~ view.uuid) }}">
                    <button type="submit" class="rounded bg-red-600 px-4 py-2 text-sm font-medium text-white">Löschen</button>
                </form>
            </div>
        </div>

        {% for type, messages in app.flashes %}
            {% for message in messages %}
                <div class="rounded border px-4 py-3 text-sm {{ type == 'error' ? 'border-red-200 bg-red-50 text-red-700' : 'border-emerald-200 bg-emerald-50 text-emerald-700' }}">
                    {{ message }}
                </div>
            {% endfor %}
        {% endfor %}

        <div class="grid gap-6 lg:grid-cols-3">
            <div class="rounded border border-slate-200 bg-white p-5 lg:col-span-2">
                <h2 class="mb-4 text-lg font-semibold text-slate-900">Track Details</h2>
                <dl class="grid gap-4 md:grid-cols-2">
                    <div>
                        <dt class="text-xs uppercase tracking-wide text-slate-500">Status</dt>
                        <dd class="mt-1 text-sm text-slate-900">{{ view.statusLabel }}</dd>
                    </div>
                    <div>
                        <dt class="text-xs uppercase tracking-wide text-slate-500">Progress</dt>
                        <dd class="mt-1 text-sm text-slate-900">{{ view.progress }}%</dd>
                    </div>
                    <div>
                        <dt class="text-xs uppercase tracking-wide text-slate-500">Erstellt am</dt>
                        <dd class="mt-1 text-sm text-slate-900">{{ view.createdAt }}</dd>
                    </div>
                    <div>
                        <dt class="text-xs uppercase tracking-wide text-slate-500">ISRC</dt>
                        <dd class="mt-1 text-sm text-slate-900">{{ view.isrc ?: '—' }}</dd>
                    </div>
                    <div>
                        <dt class="text-xs uppercase tracking-wide text-slate-500">Publishing Name</dt>
                        <dd class="mt-1 text-sm text-slate-900">{{ view.publishingName ?: '—' }}</dd>
                    </div>
                    <div class="md:col-span-2">
                        <dt class="text-xs uppercase tracking-wide text-slate-500">Notizen</dt>
                        <dd class="mt-1 whitespace-pre-line text-sm text-slate-900">{{ view.notes ?: 'Keine Notizen vorhanden.' }}</dd>
                    </div>
                </dl>
            </div>

            <div class="rounded border border-slate-200 bg-white p-5">
                <h2 class="mb-4 text-lg font-semibold text-slate-900">Aktuelle Datei</h2>
                {% if view.trackFile %}
                    <div class="space-y-3 text-sm text-slate-700">
                        <p><span class="font-medium">Datei:</span> {{ view.trackFile.originalFilename }}</p>
                        <p><span class="font-medium">Typ:</span> {{ view.trackFile.mimeType }}</p>
                        <p><span class="font-medium">Hochgeladen:</span> {{ view.trackFile.uploadedAt }}</p>
                        {% include '@trackmanagement.presentation/_audio_player.html.twig' with { playbackUrl: view.trackFile.playbackUrl } only %}
                        <form
                            action="{{ view.trackFile.replaceUrl }}"
                            method="post"
                            enctype="multipart/form-data"
                            class="space-y-2"
                            data-controller="file-upload"
                        >
                            <input
                                type="file"
                                name="track_file"
                                accept=".mp3,.wav,audio/mpeg,audio/wav"
                                class="hidden"
                                data-file-upload-target="input"
                                data-action="change->file-upload#submitOnChange"
                            >
                            <button type="button" class="rounded bg-slate-900 px-4 py-2 text-sm font-medium text-white" data-action="file-upload#openPicker">Datei ersetzen</button>
                            <p class="text-xs text-slate-500">Erlaubte Formate: MP3 oder WAV, maximal 250 MB</p>
                        </form>
                        <div class="flex gap-2">
                            <a href="{{ view.trackFile.exportMp3Url }}" class="rounded border border-slate-300 px-3 py-2 text-sm font-medium text-slate-900">Export MP3</a>
                            <a href="{{ view.trackFile.exportWavUrl }}" class="rounded border border-slate-300 px-3 py-2 text-sm font-medium text-slate-900">Export WAV</a>
                        </div>
                        {% if view.trackFile.originalFilename|lower ends with '.mp3' %}
                            <p class="text-xs text-amber-700">Hinweis: Ein WAV-Export aus einer MP3 verbessert die Audioqualität nicht. Er ist nur für Kompatibilität mit WAV-basierten Workflows gedacht.</p>
                        {% endif %}
                    </div>
                {% else %}
                    <form
                        action="{{ path('file_import.presentation.upload', { trackUuid: view.uuid }) }}"
                        method="post"
                        enctype="multipart/form-data"
                        class="space-y-3"
                        data-controller="file-upload"
                    >
                        <p class="text-sm text-slate-600">Noch keine Audiodatei vorhanden.</p>
                        <input
                            type="file"
                            name="track_file"
                            accept=".mp3,.wav,audio/mpeg,audio/wav"
                            class="hidden"
                            data-file-upload-target="input"
                            data-action="change->file-upload#submitOnChange"
                        >
                        <button type="button" class="rounded bg-slate-900 px-4 py-2 text-sm font-medium text-white" data-action="file-upload#openPicker">Datei hochladen</button>
                        <p class="text-xs text-slate-500">Erlaubte Formate: MP3 oder WAV, maximal 250 MB</p>
                    </form>
                {% endif %}
            </div>
        </div>

        <div class="rounded border border-slate-200 bg-white p-5">
            <div class="mb-4 flex items-center justify-between">
                <h2 class="text-lg font-semibold text-slate-900">Projekte</h2>
                <span class="text-sm text-slate-600">{{ view.projectMemberships|length }} {{ view.projectMemberships|length == 1 ? 'Zuordnung' : 'Zuordnungen' }}</span>
            </div>

            <div class="space-y-3">
                {% for project in view.projectMemberships %}
                    <div class="rounded border border-slate-200 px-4 py-3">
                        <div class="flex flex-col gap-1 sm:flex-row sm:items-center sm:justify-between">
                            <div>
                                <p class="text-sm font-medium text-slate-900">{{ project.projectTitle }}</p>
                                <p class="text-xs uppercase tracking-wide text-slate-500">{{ project.categoryName }} · Position {{ project.position }}</p>
                            </div>
                            <a href="{{ project.showUrl }}" class="text-sm text-slate-900 underline">Projekt ansehen</a>
                        </div>
                    </div>
                {% else %}
                    <p class="text-sm text-slate-600">Dieser Track ist aktuell keinem Projekt zugeordnet.</p>
                {% endfor %}
            </div>
        </div>

        <div class="rounded border border-slate-200 bg-white p-5">
            <div class="mb-4 flex items-center justify-between">
                <h2 class="text-lg font-semibold text-slate-900">Checkliste</h2>
                <span class="text-sm text-slate-600">{{ view.progress }}% erledigt</span>
            </div>

            <p class="mb-4 text-sm text-slate-600">Items können per Drag-and-Drop neu angeordnet werden.</p>

            <div
                class="space-y-3"
                data-controller="checklist-reorder"
                data-action="dragover->checklist-reorder#dragOver drop->checklist-reorder#drop"
            >
                {% for item in view.checklistItems %}
                    <div
                        class="group rounded border border-slate-200 p-3 transition hover:border-slate-300 hover:bg-slate-50 cursor-pointer"
                        draggable="true"
                        data-checklist-reorder-target="item"
                        data-item-uuid="{{ item.uuid }}"
                        data-action="dragstart->checklist-reorder#startDrag dragend->checklist-reorder#endDrag"
                    >
                        <div class="flex flex-col gap-3 md:flex-row md:items-center md:justify-between">
                            <form action="{{ item.toggleUrl }}" method="post" class="flex items-center gap-3">
                                <input type="hidden" name="is_completed" value="{{ item.isCompleted ? '0' : '1' }}">
                                <span
                                    class="inline-flex h-7 w-7 shrink-0 items-center justify-center self-center text-slate-500 cursor-pointer select-none leading-none transition group-hover:text-slate-600"
                                    title="Ziehen zum Sortieren"
                                    data-drag-handle
                                >
                                    <svg class="block h-4 w-4" viewBox="0 0 8 12" fill="currentColor" aria-hidden="true">
                                        <circle cx="2" cy="2" r="1"></circle>
                                        <circle cx="6" cy="2" r="1"></circle>
                                        <circle cx="2" cy="6" r="1"></circle>
                                        <circle cx="6" cy="6" r="1"></circle>
                                        <circle cx="2" cy="10" r="1"></circle>
                                        <circle cx="6" cy="10" r="1"></circle>
                                    </svg>
                                    <span class="sr-only">Ziehen</span>
                                </span>
                                <button type="submit" class="rounded border border-slate-300 px-3 py-2 text-sm font-medium text-slate-900">
                                    {{ item.isCompleted ? 'Als offen markieren' : 'Als erledigt markieren' }}
                                </button>
                                <span class="text-sm {{ item.isCompleted ? 'text-emerald-700 line-through' : 'text-slate-900' }}">{{ item.label }}</span>
                            </form>

                            <div class="flex flex-col gap-2 md:flex-row">
                                <form action="{{ item.renameUrl }}" method="post" class="flex gap-2">
                                    <input type="text" name="label" value="{{ item.label }}" class="rounded border border-slate-300 px-3 py-2 text-sm cursor-text">
                                    <button type="submit" class="rounded border border-slate-300 px-3 py-2 text-sm font-medium text-slate-900">Umbenennen</button>
                                </form>
                                <form action="{{ item.removeUrl }}" method="post">
                                    <button type="submit" class="rounded border border-red-300 px-3 py-2 text-sm font-medium text-red-700">Entfernen</button>
                                </form>
                            </div>
                        </div>
                    </div>
                {% endfor %}

                <form action="{{ view.checklistReorderUrl }}" method="post" class="hidden" data-checklist-reorder-target="form">
                    <input type="hidden" name="ordered_item_uuids" value="" data-checklist-reorder-target="input">
                </form>

                <p class="hidden" aria-live="polite" data-checklist-reorder-target="status"></p>
            </div>

            <form action="{{ view.checklistAddUrl }}" method="post" class="mt-4 flex gap-2">
                <input type="text" name="label" placeholder="Neuen Checklisten-Eintrag anlegen" class="w-full rounded border border-slate-300 px-3 py-2 text-sm">
                <button type="submit" class="rounded bg-slate-900 px-4 py-2 text-sm font-medium text-white">Hinzufügen</button>
            </form>
        </div>
    </div>
{% endblock %}
