{% extends '@common.presentation/base_appshell.html.twig' %}

{% block body %}
    <div class="mx-auto w-full max-w-6xl space-y-6 p-4 sm:p-6">
        <div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
            <div>
                <h1 class="text-3xl font-semibold text-slate-900">Track Manager</h1>
                <p class="text-sm text-slate-600">Verwalte Tracks, Checklisten und aktuelle Audiodateien.</p>
            </div>
            <div class="flex flex-wrap gap-3">
                <a href="{{ path('project_management.presentation.index') }}" class="inline-flex items-center justify-center rounded border border-slate-300 px-4 py-2 text-sm font-medium text-slate-900">Zu Projekten</a>
                <a href="{{ view.createUrl }}" class="inline-flex items-center justify-center rounded bg-slate-900 px-4 py-2 text-sm font-medium text-white">Neuen Track erstellen</a>
            </div>
        </div>

        {% for type, messages in app.flashes %}
            {% for message in messages %}
                <div class="rounded border px-4 py-3 text-sm {{ type == 'error' ? 'border-red-200 bg-red-50 text-red-700' : 'border-emerald-200 bg-emerald-50 text-emerald-700' }}">
                    {{ message }}
                </div>
            {% endfor %}
        {% endfor %}

        <form method="get" class="grid gap-3 rounded border border-slate-200 bg-white p-4 md:grid-cols-4 md:gap-4">
            <input type="text" name="q" value="{{ view.searchQuery }}" placeholder="Suche nach TrackNumber, Beat Name oder Title" class="rounded border border-slate-300 px-3 py-2 text-sm">
            <select name="status" class="rounded border border-slate-300 px-3 py-2 text-sm">
                <option value="">Alle Status</option>
                <option value="new" {{ view.statusFilter == 'new' ? 'selected' : '' }}>New</option>
                <option value="in_progress" {{ view.statusFilter == 'in_progress' ? 'selected' : '' }}>In Progress</option>
                <option value="done" {{ view.statusFilter == 'done' ? 'selected' : '' }}>Done</option>
                <option value="not_finished" {{ view.statusFilter == 'not_finished' ? 'selected' : '' }}>Nicht fertig</option>
            </select>
            <select name="sortBy" class="rounded border border-slate-300 px-3 py-2 text-sm">
                <option value="updatedAt" {{ view.sortBy == 'updatedAt' ? 'selected' : '' }}>Letzte Änderung</option>
                <option value="trackNumber" {{ view.sortBy == 'trackNumber' ? 'selected' : '' }}>TrackNumber</option>
                <option value="createdAt" {{ view.sortBy == 'createdAt' ? 'selected' : '' }}>Erstellt</option>
                <option value="progress" {{ view.sortBy == 'progress' ? 'selected' : '' }}>Progress</option>
                <option value="status" {{ view.sortBy == 'status' ? 'selected' : '' }}>Status</option>
            </select>
            <div class="flex gap-2">
                <select name="sortDirection" class="w-full rounded border border-slate-300 px-3 py-2 text-sm">
                    <option value="DESC" {{ view.sortDirection == 'DESC' ? 'selected' : '' }}>Absteigend</option>
                    <option value="ASC" {{ view.sortDirection == 'ASC' ? 'selected' : '' }}>Aufsteigend</option>
                </select>
                <button type="submit" class="rounded bg-slate-900 px-4 py-2 text-sm font-medium text-white">Filtern</button>
            </div>
        </form>

        <div class="space-y-3 md:hidden">
            {% for item in view.items %}
                <article class="rounded border border-slate-200 bg-white p-4 shadow-sm">
                    <div class="mb-3 flex items-start justify-between gap-3">
                        <div class="min-w-0">
                            <p class="text-xs font-medium uppercase tracking-wide text-slate-500">Track {{ item.trackNumber }}</p>
                        </div>
                        <span class="shrink-0 rounded bg-slate-100 px-2 py-1 text-xs font-medium text-slate-700">{{ item.statusLabel }}</span>
                    </div>

                    <div class="grid gap-2 text-sm text-slate-700">
                        <div class="flex items-start justify-between gap-3">
                            <span class="text-slate-500">Beat</span>
                            <span class="text-right">{{ item.beatName }}</span>
                        </div>
                        <div class="flex items-start justify-between gap-3">
                            <span class="text-slate-500">Publishing Name</span>
                            <span class="text-right">{{ item.publishingName ?: '—' }}</span>
                        </div>
                        <div class="flex items-start justify-between gap-3">
                            <span class="text-slate-500">BPM</span>
                            <span class="text-right">
                                {% for bpm in item.bpmLabel|split(', ') %}
                                    <span class="block">{{ bpm }}</span>
                                {% endfor %}
                            </span>
                        </div>
                        <div class="flex items-start justify-between gap-3">
                            <span class="text-slate-500">Key</span>
                            <span class="text-right">{{ item.musicalKey }}</span>
                        </div>
                        <div class="flex items-start justify-between gap-3">
                            <span class="text-slate-500">Progress</span>
                            <span class="text-right">{{ item.progress }}%</span>
                        </div>
                        <div class="flex items-start justify-between gap-3">
                            <span class="text-slate-500">Datei</span>
                            <span class="text-right">{{ item.hasCurrentFile ? 'Vorhanden' : 'Keine Datei' }}</span>
                        </div>
                    </div>

                    <div class="mt-4 flex gap-3">
                        <a href="{{ item.showUrl }}" class="text-sm font-medium text-slate-900 underline">Details</a>
                        <a href="{{ item.editUrl }}" class="text-sm font-medium text-slate-900 underline">Bearbeiten</a>
                    </div>
                </article>
            {% else %}
                <div class="rounded border border-slate-200 bg-white px-4 py-8 text-center text-slate-500">Noch keine Tracks vorhanden.</div>
            {% endfor %}
        </div>

        <div class="hidden overflow-x-auto rounded border border-slate-200 bg-white md:block">
            <table class="min-w-[52rem] w-full table-fixed divide-y divide-slate-200 text-sm lg:min-w-0">
                <colgroup>
                    <col class="w-[8%]">
                    <col class="w-[18%]">
                    <col class="w-[18%]">
                    <col class="w-[8%]">
                    <col class="w-[7%]">
                    <col class="w-[10%]">
                    <col class="w-[8%]">
                    <col class="w-[12%]">
                    <col class="w-[19%]">
                </colgroup>
                <thead class="bg-slate-50">
                    <tr>
                        <th class="px-3 py-3 text-left font-medium text-slate-600">ID</th>
                        <th class="px-3 py-3 text-left font-medium text-slate-600">Beat Name</th>
                        <th class="px-3 py-3 text-left font-medium text-slate-600">Publishing Name</th>
                        <th class="px-3 py-3 text-left font-medium text-slate-600">BPM</th>
                        <th class="px-3 py-3 text-left font-medium text-slate-600">Key</th>
                        <th class="px-3 py-3 text-left font-medium text-slate-600">Status</th>
                        <th class="px-3 py-3 text-left font-medium text-slate-600">Progress</th>
                        <th class="px-3 py-3 text-left font-medium text-slate-600">Datei</th>
                        <th class="px-3 py-3 text-left font-medium text-slate-600">Aktionen</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-100">
                    {% for item in view.items %}
                        <tr>
                            <td class="px-3 py-3 font-medium text-slate-900">{{ item.trackNumber }}</td>
                            <td class="px-3 py-3 text-slate-700">{{ item.beatName }}</td>
                            <td class="px-3 py-3 text-slate-700 truncate" title="{{ item.publishingName ?: '' }}">{{ item.publishingName ?: '—' }}</td>
                            <td class="px-3 py-3 text-slate-700">
                                {% for bpm in item.bpmLabel|split(', ') %}
                                    <div>{{ bpm }}</div>
                                {% endfor %}
                            </td>
                            <td class="px-3 py-3 text-slate-700">{{ item.musicalKey }}</td>
                            <td class="px-3 py-3 text-slate-700">{{ item.statusLabel }}</td>
                            <td class="px-3 py-3 text-slate-700">{{ item.progress }}%</td>
                            <td class="px-3 py-3 text-slate-700">{{ item.hasCurrentFile ? 'Vorhanden' : 'Keine Datei' }}</td>
                            <td class="px-3 py-3">
                                <div class="flex flex-col gap-1 xl:flex-row xl:gap-2">
                                    <a href="{{ item.showUrl }}" class="text-slate-900 underline">Details</a>
                                    <a href="{{ item.editUrl }}" class="text-slate-900 underline">Bearbeiten</a>
                                </div>
                            </td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="9" class="px-4 py-8 text-center text-slate-500">Noch keine Tracks vorhanden.</td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
{% endblock %}
