{% if item.hasCurrentFile and item.trackFile %}
    <div class="inline-block" data-controller="dialog">
        <button type="button" class="text-left underline hover:text-slate-900" data-action="dialog#open">Vorhanden</button>
        <dialog
            class="fixed left-1/2 top-1/2 m-0 w-full max-w-2xl -translate-x-1/2 -translate-y-1/2 rounded border border-slate-200 p-0 shadow-xl backdrop:bg-slate-900/30"
            data-dialog-target="dialog"
            data-action="click->dialog#closeOnBackdrop"
        >
            <div class="space-y-4 p-6">
                <div class="flex items-start justify-between gap-4">
                    <div>
                        <h2 class="text-lg font-semibold text-slate-900">Bereits hochgeladene Datei</h2>
                        <p class="text-sm text-slate-600">Fuer diesen Track existiert bereits eine Audiodatei. Du kannst sie hier direkt pruefen und bei Bedarf ersetzen.</p>
                    </div>
                    <button type="button" class="rounded border border-slate-300 px-3 py-2 text-sm text-slate-700" data-action="dialog#close">Schließen</button>
                </div>

                <div class="space-y-3 text-sm text-slate-700">
                    <p><span class="font-medium">Datei:</span> {{ item.trackFile.originalFilename }}</p>
                    <p><span class="font-medium">Typ:</span> {{ item.trackFile.mimeType }}</p>
                    <p><span class="font-medium">Hochgeladen:</span> {{ item.trackFile.uploadedAt }}</p>
                    {% include '@trackmanagement.presentation/_audio_player.html.twig' with { playbackUrl: item.trackFile.playbackUrl } only %}
                    {% if not item.cancelled %}
                        <form
                            action="{{ item.trackFile.replaceUrl }}"
                            method="post"
                            enctype="multipart/form-data"
                            class="space-y-2"
                            data-controller="file-upload"
                        >
                            <input type="hidden" name="redirect_to" value="{{ currentUrl }}">
                            <input
                                type="file"
                                name="track_file"
                                accept=".mp3,.wav,audio/mpeg,audio/wav"
                                class="hidden"
                                data-file-upload-target="input"
                                data-action="change->file-upload#submitOnChange"
                            >
                            <button type="button" class="rounded bg-slate-900 px-4 py-2 text-sm font-medium text-white" data-action="file-upload#openPicker">Datei ersetzen</button>
                            <p class="text-xs text-slate-500">Erlaubte Formate: MP3 oder WAV, maximal 250 MB</p>
                        </form>
                    {% else %}
                        <p class="text-xs text-slate-500">Archivierte Tracks sind schreibgeschützt. Bestehende Dateien bleiben nur lesbar.</p>
                    {% endif %}
                </div>
            </div>
        </dialog>
    </div>
{% elseif item.cancelled %}
    <span class="text-slate-400" title="Archivierte Tracks können keine neuen Dateien erhalten.">Nicht möglich</span>
{% else %}
    <form action="{{ item.uploadUrl }}" method="post" enctype="multipart/form-data" class="inline-block" data-controller="file-upload">
        <input type="hidden" name="redirect_to" value="{{ currentUrl }}">
        <input
            type="file"
            name="track_file"
            accept=".mp3,.wav,audio/mpeg,audio/wav"
            class="hidden"
            data-file-upload-target="input"
            data-action="change->file-upload#submitOnChange"
        >
        <button type="button" class="text-left underline hover:text-slate-900" data-action="file-upload#openPicker">Keine Datei</button>
    </form>
{% endif %}
