<div class="space-y-4" data-live-search-current-page="{{ view.currentPage }}">
    <div class="space-y-3 md:hidden">
        {% for item in view.items %}
            <article class="rounded border border-slate-200 bg-white p-4 shadow-sm {{ item.cancelled ? 'opacity-60' : '' }}">
                <div class="mb-3 flex items-start justify-between gap-3">
                    <div class="min-w-0">
                        <p class="text-xs font-medium uppercase tracking-wide text-slate-500">Track {{ item.trackNumber }}</p>
                    </div>
                    <span class="shrink-0 rounded bg-slate-100 px-2 py-1 text-xs font-medium text-slate-700">{{ item.statusLabel }}</span>
                </div>

                <div class="grid gap-2 text-sm text-slate-700">
                    <div class="flex items-start justify-between gap-3">
                        <span class="text-slate-500">Beat</span>
                        <div class="min-w-0 text-right">
                            <span>{{ item.beatName }}</span>
                            {% include '@trackmanagement.presentation/_project_badges.html.twig' with { item: item, wrapperClass: 'justify-end' } only %}
                        </div>
                    </div>
                    <div class="flex items-start justify-between gap-3">
                        <span class="text-slate-500">Publishing Name</span>
                        <span class="text-right">{{ item.publishingName ?: '—' }}</span>
                    </div>
                    <div class="flex items-start justify-between gap-3">
                        <span class="text-slate-500">BPM</span>
                        <span class="text-right">
                            {% for bpm in item.bpmLabel|split(', ') %}
                                <span class="block">{{ bpm }}</span>
                            {% endfor %}
                        </span>
                    </div>
                    <div class="flex items-start justify-between gap-3">
                        <span class="text-slate-500">Key</span>
                        <span class="text-right">
                            {% for musicalKey in item.musicalKeyLabel|split(', ') %}
                                <span class="block">{{ musicalKey }}</span>
                            {% endfor %}
                        </span>
                    </div>
                    <div class="flex items-start justify-between gap-3">
                        <span class="text-slate-500">Published</span>
                        <span class="text-right">
                            <span
                                class="inline-flex h-4 w-4 items-center justify-center rounded border {{ item.published ? 'border-emerald-200 bg-emerald-100 text-emerald-700' : 'border-slate-300 bg-white text-transparent' }}"
                                aria-label="{{ item.published ? 'Veröffentlicht' : 'Nicht veröffentlicht' }}"
                                title="{{ item.published ? 'Veröffentlicht' : 'Nicht veröffentlicht' }}"
                            >
                                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" fill="currentColor" class="h-3 w-3">
                                    <path fill-rule="evenodd" d="M13.28 4.22a.75.75 0 0 1 0 1.06l-6.25 6.25a.75.75 0 0 1-1.06 0L2.72 8.28a.75.75 0 1 1 1.06-1.06l2.72 2.72 5.72-5.72a.75.75 0 0 1 1.06 0Z" clip-rule="evenodd" />
                                </svg>
                            </span>
                        </span>
                    </div>
                    <div class="flex items-start justify-between gap-3">
                        <span class="text-slate-500">Progress</span>
                        <span class="text-right">{{ item.progress }}%</span>
                    </div>
                    <div class="flex items-start justify-between gap-3">
                        <span class="text-slate-500">Datei</span>
                        <div class="text-right">
                            {% include '@trackmanagement.presentation/_file_overview_action.html.twig' with { item: item, currentUrl: view.currentUrl } only %}
                        </div>
                    </div>
                </div>

                <div class="mt-4 flex justify-end gap-2">
                    <a href="{{ item.showUrl }}" title="Details" aria-label="Details" class="inline-flex h-8 w-8 items-center justify-center text-slate-600 transition hover:text-slate-900">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="h-4 w-4">
                            <path d="M10 4.5c-3.878 0-7.162 2.285-8.327 5.5C2.838 13.215 6.122 15.5 10 15.5s7.162-2.285 8.327-5.5C17.162 6.785 13.878 4.5 10 4.5ZM10 13a3 3 0 1 1 0-6 3 3 0 0 1 0 6Z" />
                        </svg>
                    </a>
                    {% if not item.cancelled %}
                        <a href="{{ item.editUrl }}" title="Bearbeiten" aria-label="Bearbeiten" class="inline-flex h-8 w-8 items-center justify-center text-slate-600 transition hover:text-slate-900">
                            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="h-4 w-4">
                                <path d="m13.5 4.5 2 2L7.75 14.25l-2.5.5.5-2.5L13.5 4.5Zm1.06-1.06a1.5 1.5 0 0 1 2.122 0l.879.878a1.5 1.5 0 0 1 0 2.122l-.652.652-2-2 .651-.646Z" />
                            </svg>
                        </a>
                    {% endif %}
                </div>
            </article>
        {% else %}
            <div class="rounded border border-slate-200 bg-white px-4 py-8 text-center text-slate-500">Noch keine Tracks vorhanden.</div>
        {% endfor %}
    </div>

    <div class="hidden overflow-x-auto rounded border border-slate-200 bg-white md:block">
        <table class="min-w-[52rem] w-full table-fixed divide-y divide-slate-200 text-sm lg:min-w-0">
            <colgroup>
                <col class="w-[8%]">
                <col class="w-[18%]">
                <col class="w-[26%]">
                <col class="w-[8%]">
                <col class="w-[7%]">
                <col class="w-[8%]">
                <col class="w-[8%]">
                <col class="w-[12%]">
                <col class="w-[8%]">
                <col class="w-[11%]">
            </colgroup>
            <thead class="bg-slate-50">
                <tr>
                    <th class="px-3 py-3 text-left font-medium text-slate-600">ID</th>
                    <th class="px-3 py-3 text-left font-medium text-slate-600">
                        <div class="relative inline-flex items-center gap-1 group">
                            <span>Beat Name</span>
                            <button type="button" aria-label="Info zu Beat Name" class="relative top-px inline-flex h-4 w-4 items-center justify-center rounded-full text-slate-400 transition hover:text-slate-700 focus:text-slate-700">
                                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="h-4 w-4">
                                    <path fill-rule="evenodd" d="M18 10A8 8 0 1 1 2 10a8 8 0 0 1 16 0ZM9.25 8a.75.75 0 0 1 1.5 0v.25a.75.75 0 0 1-1.5 0V8Zm0 3a.75.75 0 0 1 .75-.75h.007a.75.75 0 0 1 .743.648l.25 2a.75.75 0 0 1-1.488.204l-.16-1.28H10a.75.75 0 0 1-.75-.75Z" clip-rule="evenodd" />
                                </svg>
                            </button>
                            <div class="pointer-events-none absolute left-0 top-full z-10 mt-2 hidden w-56 rounded border border-slate-200 bg-white p-3 text-xs font-normal normal-case leading-relaxed text-slate-700 shadow-lg group-hover:block group-focus-within:block">
                                Interner Arbeitsname des Beats zur Organisation im Track Manager.
                            </div>
                        </div>
                    </th>
                    <th class="px-3 py-3 text-left font-medium text-slate-600">
                        <div class="relative inline-flex items-center gap-1 group">
                            <span>Publishing Name</span>
                            <button type="button" aria-label="Info zu Publishing Name" class="relative top-px inline-flex h-4 w-4 items-center justify-center rounded-full text-slate-400 transition hover:text-slate-700 focus:text-slate-700">
                                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="h-4 w-4">
                                    <path fill-rule="evenodd" d="M18 10A8 8 0 1 1 2 10a8 8 0 0 1 16 0ZM9.25 8a.75.75 0 0 1 1.5 0v.25a.75.75 0 0 1-1.5 0V8Zm0 3a.75.75 0 0 1 .75-.75h.007a.75.75 0 0 1 .743.648l.25 2a.75.75 0 0 1-1.488.204l-.16-1.28H10a.75.75 0 0 1-.75-.75Z" clip-rule="evenodd" />
                                </svg>
                            </button>
                            <div class="pointer-events-none absolute left-0 top-full z-10 mt-2 hidden w-56 rounded border border-slate-200 bg-white p-3 text-xs font-normal normal-case leading-relaxed text-slate-700 shadow-lg group-hover:block group-focus-within:block">
                                Geplanter finaler Songname für Veröffentlichung und Release.
                            </div>
                        </div>
                    </th>
                    <th class="px-3 py-3 text-left font-medium text-slate-600">BPM</th>
                    <th class="px-3 py-3 text-left font-medium text-slate-600">Key</th>
                    <th class="px-3 py-3 text-left font-medium text-slate-600">Status</th>
                    <th class="px-3 py-3 text-left font-medium text-slate-600">Published</th>
                    <th class="px-3 py-3 text-left font-medium text-slate-600">Progress</th>
                    <th class="px-3 py-3 text-left font-medium text-slate-600">Datei</th>
                    <th class="px-3 py-3 text-left font-medium text-slate-600">Aktionen</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-slate-100">
                {% for item in view.items %}
                    <tr class="{{ item.cancelled ? 'bg-slate-50 opacity-60' : '' }}">
                        <td class="px-3 py-3 font-medium text-slate-900">{{ item.trackNumber }}</td>
                        <td class="px-3 py-3 text-slate-700">
                            <div class="min-w-0">
                                <div>{{ item.beatName }}</div>
                                {% include '@trackmanagement.presentation/_project_badges.html.twig' with { item: item } only %}
                            </div>
                        </td>
                        <td class="px-3 py-3 text-slate-700 truncate" title="{{ item.publishingName ?: '' }}">{{ item.publishingName ?: '—' }}</td>
                        <td class="px-3 py-3 text-slate-700">
                            {% for bpm in item.bpmLabel|split(', ') %}
                                <div>{{ bpm }}</div>
                            {% endfor %}
                        </td>
                        <td class="px-3 py-3 text-slate-700">
                            {% for musicalKey in item.musicalKeyLabel|split(', ') %}
                                <div>{{ musicalKey }}</div>
                            {% endfor %}
                        </td>
                        <td class="px-3 py-3 text-slate-700">{{ item.statusLabel }}</td>
                        <td class="px-3 py-3 text-slate-700">
                            <span
                                class="inline-flex h-4 w-4 items-center justify-center rounded border {{ item.published ? 'border-emerald-200 bg-emerald-100 text-emerald-700' : 'border-slate-300 bg-white text-transparent' }}"
                                aria-label="{{ item.published ? 'Veröffentlicht' : 'Nicht veröffentlicht' }}"
                                title="{{ item.published ? 'Veröffentlicht' : 'Nicht veröffentlicht' }}"
                            >
                                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" fill="currentColor" class="h-3 w-3">
                                    <path fill-rule="evenodd" d="M13.28 4.22a.75.75 0 0 1 0 1.06l-6.25 6.25a.75.75 0 0 1-1.06 0L2.72 8.28a.75.75 0 1 1 1.06-1.06l2.72 2.72 5.72-5.72a.75.75 0 0 1 1.06 0Z" clip-rule="evenodd" />
                                </svg>
                            </span>
                        </td>
                        <td class="px-3 py-3 text-slate-700">{{ item.progress }}%</td>
                        <td class="px-3 py-3 text-slate-700">
                            {% include '@trackmanagement.presentation/_file_overview_action.html.twig' with { item: item, currentUrl: view.currentUrl } only %}
                        </td>
                        <td class="px-3 py-3">
                            <div class="flex justify-end gap-2">
                                <a href="{{ item.showUrl }}" title="Details" aria-label="Details" class="inline-flex h-8 w-8 items-center justify-center text-slate-600 transition hover:text-slate-900">
                                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="h-4 w-4">
                                        <path d="M10 4.5c-3.878 0-7.162 2.285-8.327 5.5C2.838 13.215 6.122 15.5 10 15.5s7.162-2.285 8.327-5.5C17.162 6.785 13.878 4.5 10 4.5ZM10 13a3 3 0 1 1 0-6 3 3 0 0 1 0 6Z" />
                                    </svg>
                                </a>
                                {% if not item.cancelled %}
                                    <a href="{{ item.editUrl }}" title="Bearbeiten" aria-label="Bearbeiten" class="inline-flex h-8 w-8 items-center justify-center text-slate-600 transition hover:text-slate-900">
                                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="h-4 w-4">
                                            <path d="m13.5 4.5 2 2L7.75 14.25l-2.5.5.5-2.5L13.5 4.5Zm1.06-1.06a1.5 1.5 0 0 1 2.122 0l.879.878a1.5 1.5 0 0 1 0 2.122l-.652.652-2-2 .651-.646Z" />
                                        </svg>
                                    </a>
                                {% endif %}
                            </div>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="10" class="px-4 py-8 text-center text-slate-500">Noch keine Tracks vorhanden.</td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>

    <div class="flex flex-col gap-3 rounded border border-slate-200 bg-white p-4 sm:flex-row sm:items-center sm:justify-between">
        <p class="text-sm text-slate-600">
            {{ view.totalItems }} {{ view.totalItems == 1 ? 'Treffer' : 'Treffer' }} · Seite {{ view.currentPage }} von {{ view.totalPages }}
        </p>
        <div class="flex flex-wrap items-center gap-2">
            {% if view.previousPageUrl %}
                <a href="{{ view.previousPageUrl }}" data-live-search-page="{{ view.currentPage - 1 }}" class="rounded border border-slate-300 px-3 py-2 text-sm text-slate-900">Zurück</a>
            {% endif %}
            {% for pageLink in view.pageLinks %}
                <a
                    href="{{ pageLink.url }}"
                    data-live-search-page="{{ pageLink.page }}"
                    class="rounded border px-3 py-2 text-sm {{ pageLink.isCurrent ? 'border-slate-900 bg-slate-900 text-white' : 'border-slate-300 text-slate-900' }}"
                >{{ pageLink.page }}</a>
            {% endfor %}
            {% if view.nextPageUrl %}
                <a href="{{ view.nextPageUrl }}" data-live-search-page="{{ view.currentPage + 1 }}" class="rounded border border-slate-300 px-3 py-2 text-sm text-slate-900">Weiter</a>
            {% endif %}
        </div>
    </div>
</div>
